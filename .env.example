# You Vs Many — environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit a real key.

# --- Model provider selection ---
# "qwen"  -> call the live Qwen Cloud API (requires network + key)
# "mock"  -> deterministic offline provider (no network, reproducible). Default.
YVM_PROVIDER=mock

# --- Qwen Cloud (OpenAI-compatible) ---
# Key looks like: sk-ws-...   (provided out of band; do not commit)
QWEN_API_KEY=sk-replace-me
# Base URL for the OpenAI-compatible chat endpoint.
# The adapter POSTs to ${QWEN_BASE_URL}/chat/completions
QWEN_BASE_URL=https://api.qwencloud.com/v1
# Core reasoning model (see blueprint "Project at a glance")
QWEN_TEXT_MODEL=qwen3.7-plus

# --- Run config ---
YVM_RUN_DIR=runs
