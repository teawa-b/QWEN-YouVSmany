# Secrets — never commit real keys
.env
.env.local
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Episode artifacts written at runtime
/runs/
/backend/runs/
/.artifacts/
/backend/.artifacts/
/output/

# Node
node_modules/
package-lock.json

# Vendored runtime libraries are committed (the Python build/ pattern above
# would otherwise swallow frontend/vendor/three/build/)
!frontend/vendor/
!frontend/vendor/**

# Frontend build outputs if a bundler is added later
/frontend/dist/
/frontend/build/

# Local server logs
*.log

# OS / editor
.DS_Store
.idea/
.vscode/
.claude/
.playwright-cli/
