# You Vs Many — environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit a real key.

# --- Model provider selection ---
# "qwen"  -> call the live Qwen Cloud API (requires network + key)
# "mock"  -> deterministic offline provider (no network, reproducible). Default.
YVM_PROVIDER=mock

# --- Qwen Cloud (OpenAI-compatible) ---
# Key looks like: sk-ws-...   (provided out of band; do not commit)
QWEN_API_KEY=sk-replace-me
# Base URL for the OpenAI-compatible chat endpoint.
# The adapter POSTs to ${QWEN_BASE_URL}/chat/completions
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Core reasoning model (see blueprint "Project at a glance")
QWEN_TEXT_MODEL=qwen3.7-plus

# --- TTS for the master audio timeline (Phase 2) ---
# "qwen" -> synthesise lines with a Qwen Cloud TTS model (requires network + key)
# "mock" -> deterministic offline durations, no audio rendered. Default.
YVM_TTS_PROVIDER=mock
# DashScope NATIVE API root (not the OpenAI-compatible one above).
# The TTS adapter POSTs to ${QWEN_DASHSCOPE_URL}/services/aigc/multimodal-generation/generation
QWEN_DASHSCOPE_URL=https://dashscope-intl.aliyuncs.com/api/v1
# Qwen Cloud TTS model id (confirm exact id + voice ids against DashScope docs).
QWEN_TTS_MODEL=qwen-tts

# --- Run config ---
YVM_RUN_DIR=runs
